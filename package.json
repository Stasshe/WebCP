    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "24.5.1",
    "rollup": "^4.60.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
