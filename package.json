{
  "name": "fluxa-webcp",
  "version": "0.2.0",
  "type": "module",
  "description": "ts interpreter for a competitive-programming-focused C++ subset, with AST-level step execution, full state inspection, and GCC/Clang-style diagnostics.",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src/**/*.ts tests/*.ts",
    "lint:fix": "biome check --write src/**/*.ts tests/*.ts",
    "format": "biome format src/**/*.ts tests/*.ts --write",
    "clean": "rm -rf dist",
    "dev": "pnpm web:dev",
    "web:dev": "pnpm --dir apps/web dev",
    "web:build": "pnpm --dir apps/web build",
    "web:start": "pnpm --dir apps/web start"
  },
  "keywords": [
    "cpp",
    "debugger",
    "compiler",
    "cp",
    "competitive programming",
    "web",
    "js",
    "typescript",
    "ts"
  ],
  "author": "Stasshe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stasshe/Fluxa-WebCP"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "24.5.1",
    "rollup": "^4.60.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@replit/codemirror-indentation-markers": "^6.5.3"
  }
}
